{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PROJECT_DIR}/.claude/hooks/check-tests-before-push.sh\"",
            "timeout": 120,
            "statusMessage": "Running Playwright suite before allowing git push..."
          }
        ]
      }
    ]
  }
}
